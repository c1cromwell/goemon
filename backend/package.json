{
  "name": "argus-backend",
  "version": "2.0.0",
  "private": true,
  "description": "Argus Financial Partners backend — Hedera-aligned, production-hardened rebuild (Phase 0 + Phase 1 foundation)",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "setup": "tsx src/scripts/first-run-setup.ts",
    "seed:users": "tsx src/scripts/seed-demo-users.ts",
    "seed:marketplace": "tsx src/scripts/seed-marketplace-demo.ts",
    "reset:auth": "tsx src/scripts/reset-auth-failures.ts",
    "encrypt-keys": "tsx src/scripts/encrypt-keys.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@hashgraph/sdk": "^2.81.0",
    "@simplewebauthn/server": "^11.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
