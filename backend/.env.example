# ---- Core ----
# Anthropic API key (only needed once agent phases land; optional for Phase 0/1)
ANTHROPIC_API_KEY=

# JWT signing secret. MUST be a strong random value in production.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# The known dev default below is REJECTED when NODE_ENV=production.
JWT_SECRET=argus_dev_secret_change_in_production

PORT=3001
BASE_URL=http://localhost:3001
CREDENTIAL_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
NODE_ENV=development

# ---- Database ----
# If DATABASE_URL is set, Postgres is used. Otherwise local SQLite at ./data/argus.db.
# DATABASE_URL=postgres://argus:argus@localhost:5432/argus
SQLITE_PATH=./data/argus.db

# Optional Redis for rate limiting / cache (falls back to in-memory if unset)
# REDIS_URL=redis://localhost:6379

# ---- Auth ----
# Dev-only password auth fallback. REJECTED when NODE_ENV=production.
ALLOW_PASSWORD_AUTH=true
# Comma-separated admin email allowlist (used by admin seed/login in later phases)
ADMIN_EMAILS=

# WebAuthn relying party (passkeys) — used in Phase 3
RP_ID=localhost
RP_NAME=Argus Financial Partners
RP_ORIGIN=http://localhost:5173

# ---- Fiat → USDC on-ramp (buy USDC with fiat — the activation gap) ----
# ONRAMP_PROVIDER=simulated is prod-fatal; a real launch wires a licensed on-ramp
# (moonpay/stripe/coinbase) that takes the fiat + runs KYC under its own license.
ONRAMP_ENABLED=false
ONRAMP_PROVIDER=simulated
ONRAMP_FEE_BPS=100

# ---- Collateralized lending (PRD v2 prototype) ----
# Over-collateralized: pledge a tokenized holding (Treasury ATB, valued at par) and borrow
# USD against it. Prod-fatal — a real product needs a lender of record + licensing + real
# liquidity. MAX_LTV caps the borrow; LIQUIDATION_LTV is the seize threshold; APR is annual.
LENDING_ENABLED=false
LENDING_MAX_LTV_BPS=5000
LENDING_LIQUIDATION_LTV_BPS=7500
LENDING_APR_BPS=800

# ---- Identity / Compliance providers (adapter selection) ----
IDV_PROVIDER=simulated
SANCTIONS_PROVIDER=simulated
# PERSONA_API_KEY=
# TRM_API_KEY=

# ---- Phase 5A — Agentic account opening ----
# Risk orchestrator: "simulated" (deterministic, offline default) or "anthropic"
# (uses the @anthropic-ai/sdk scorer; requires ANTHROPIC_API_KEY).
ONBOARDING_ORCHESTRATOR=simulated
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Confidence (0..1) at/above which onboarding auto-approves; below triggers step-up.
ONBOARDING_CONFIDENCE_THRESHOLD=0.8
# Floor below which onboarding is rejected even after sub-agent step-up.
ONBOARDING_REVIEW_FLOOR=0.5
# Admin-console JWT secret. Falls back to JWT_SECRET in dev; in production it MUST
# be set and distinct from JWT_SECRET.
# ADMIN_JWT_SECRET=

# ---- Fraud engine (Stage 1 in-process seam; on by default) ----
# FRAUD_ENGINE_ENABLED: run the deterministic scorer + record a fraud_decision on
#   every money-path event. Set false to disable scoring entirely (no rows).
# FRAUD_ENGINE_ENFORCE: when true a `block` action throws FRAUD_BLOCKED; set false
#   for shadow mode (decisions recorded, transfers still settle).
FRAUD_ENGINE_ENABLED=true
FRAUD_ENGINE_ENFORCE=true

# ---- Standalone fraud engine add-on (Phase 20 Stages 2–4; the `fraud-engine/` service) ----
# Argus talks to the engine ONLY over HTTP. A lightweight local triage decides whether
# each money event is screened synchronously (blocking) or emitted fire-and-forget; the
# remote score is advisory, the local gate + account-freeze remain authoritative.
#   FRAUD_ENGINE_URL      — base URL of the engine. UNSET ⇒ client is inert (local-only).
#   FRAUD_ENGINE_API_KEY  — shared service bearer (engine validates it; engine reuses it to
#                           authenticate its freeze/flag callbacks to /api/internal/remediation).
#   FRAUD_REMOTE_ENABLED  — master switch for any call-out (default true, inert without a URL).
#   FRAUD_REMOTE_REQUIRED — fail CLOSED when the engine is unreachable on the blocking path
#                           (default false ⇒ degrade open: a missing engine never blocks money).
# FRAUD_ENGINE_URL=http://localhost:4500
# FRAUD_ENGINE_API_KEY=fraud_dev_key_change_in_production
FRAUD_REMOTE_ENABLED=true
FRAUD_REMOTE_REQUIRED=false

# ---- Trading (Phase 17 Stage 1 seam; OFF by default, kill-switch) ----
# TRADING_ENABLED: enable the simulated, isolated trading seam (order entry +
#   async settlement worker). Simulated broker ONLY — must stay false in production.
TRADING_ENABLED=false

# ---- Hedera (Phase 5; disabled by default) ----
HEDERA_ENABLED=false
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_USDC_TOKEN_ID=

# ---- Rate limiting ----
AUTH_MAX_FAILURES=5
AUTH_LOCKOUT_MINUTES=30
API_RATE_LIMIT_PER_MIN=100
